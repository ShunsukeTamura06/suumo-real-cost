{
  "manifest_version": 3,
  "name": "SUUMO 実質月額コスト",
  "version": "1.1.0",
  "description": "SUUMO賃貸物件の実質月額コスト（初期費用を24ヶ月で均した実態）を右下にオーバーレイ表示し、閲覧履歴を記録します",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://suumo.jp/chintai/jnc_*",
        "*://suumo.jp/chintai/nc_*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
